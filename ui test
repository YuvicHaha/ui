        DataDisplay.TextColor3 = Color3.fromRGB(180, 180, 185)
        DataDisplay.Font = Enum.Font.RobotoMono
        DataDisplay.TextSize = 11
        DataDisplay.TextXAlignment = Enum.TextXAlignment.Left
        DataDisplay.TextYAlignment = Enum.TextYAlignment.Top
        DataDisplay.RichText = true
        DataDisplay.Parent = LookupFrame

        -- Inner Functional Hook Logic Pipeline
        local function ExecutionSequence()
            local query = SearchBox.Text:lower()
            if query == "" then return end

            local targetPlayer = nil
            for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
                if p.Name:lower():find(query, 1, true) or p.DisplayName:lower():find(query, 1, true) then
                    targetPlayer = p
                    break
                end
            end

            if not targetPlayer then
                DataDisplay.Text = "<br/><font color='rgb(240,80,80)'><b>ERROR:</b> Target profile offline or missing.</font>"
                SearchAvatar.Image = "rbxassetid://6074246132"
                return
            end

            -- Update Avatar Visual Assets
            SearchAvatar.Image = "rbxthumb://type=AvatarHeadShot&id=" .. targetPlayer.UserId .. "&w=150&h=150"

            -- Extract state indicators securely
            local df = targetPlayer:FindFirstChild("DataFolder")
            local cash = (df and df:FindFirstChild("Currency")) and df.Currency.Value or 0
            local state = "ALIVE"
            local item = "None"
            
            local char = targetPlayer.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                local be = char:FindFirstChild("BodyEffects")
                local currentTool = char:FindFirstChildOfClass("Tool")
                
                if currentTool then item = currentTool.Name end
                
                if humanoid and humanoid.Health <= 0 then state = "DEAD"
                elseif be and be:FindFirstChild("K.O") and be["K.O"].Value then state = "KNOCKED OUT"
                elseif char:FindFirstChild("Christmas_Sock") then state = "BAGGED"
                elseif char:FindFirstChildOfClass("ForceField") then state = "FORCEFIELD"
                elseif humanoid.MoveDirection.Magnitude > 0 then state = "MOVING" end
            else
                state = "UNLOADED"
            end

            -- Format and inject raw text strings into UI layout
            DataDisplay.Text = string.format(
                "<b>@%s</b><br/>" ..
                "💵 Cash: <font color='rgb(100,220,140)'>$%s</font><br/>" ..
                "🛡️ State: %s<br/>" ..
                "🎒 Tool: %s<br/>" ..
                "📅 Age: %s Days",
                targetPlayer.Name,
                tostring(cash):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", ""),
                state, item, tostring(targetPlayer.AccountAge)
            )
        end

        -- Hook up activation connections
        SearchButton.MouseButton1Click:Connect(ExecutionSequence)
        SearchBox.FocusLost:Connect(function(enterPressed) if enterPressed then ExecutionSequence() end end)
    end

    return PageElements
end

